<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/wh_bg">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/wh_surface"
        app:elevation="0dp">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            style="@style/Widget.WH.Toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"/>
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Mini player bar -->
        <LinearLayout
            android:id="@+id/miniPlayerContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/wh_surface_panel"
            android:visibility="gone">
            <androidx.media3.ui.PlayerView
                android:id="@+id/miniPlayerView"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                app:use_controller="false"
                app:surface_type="surface_view"
                android:background="@color/wh_pure_black"/>
            <ProgressBar
                android:id="@+id/miniProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:progressTint="@color/wh_neon_gold"
                android:progressBackgroundTint="@color/wh_divider"
                android:max="100"
                android:progress="0"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/miniTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Now Playing"
                    android:fontFamily="@font/orbitron_regular"
                    android:textSize="11sp"
                    android:textColor="@color/wh_neon_gold"
                    android:singleLine="true"
                    android:ellipsize="end"/>
                <ImageButton
                    android:id="@+id/btnMiniRewind"
                    android:layout_width="32dp" android:layout_height="32dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_btn_neutral"
                    android:src="@drawable/ic_rew_custom"
                    android:padding="5dp" android:scaleType="fitCenter"/>
                <ImageButton
                    android:id="@+id/btnMiniPlayPause"
                    android:layout_width="36dp" android:layout_height="36dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_btn_gold"
                    android:src="@drawable/ic_pause_custom"
                    android:padding="6dp" android:scaleType="fitCenter"/>
                <ImageButton
                    android:id="@+id/btnMiniForward"
                    android:layout_width="32dp" android:layout_height="32dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_btn_neutral"
                    android:src="@drawable/ic_ff_custom"
                    android:padding="5dp" android:scaleType="fitCenter"/>
                <ImageButton
                    android:id="@+id/btnMiniClose"
                    android:layout_width="32dp" android:layout_height="32dp"
                    android:background="@drawable/bg_btn_red"
                    android:src="@drawable/ic_close_custom"
                    android:padding="5dp" android:scaleType="fitCenter"/>
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/wh_divider"/>

        <TextView
            android:id="@+id/empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="24dp"
            android:gravity="center"
            android:text="No videos in vault.
Load an archive to begin."
            android:fontFamily="@font/orbitron_regular"
            android:textSize="13sp"
            android:textColor="@color/wh_on_muted"
            android:visibility="gone"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp"
            android:clipToPadding="false"/>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/wh_surface"
            app:menu="@menu/menu_bottom_nav"
            app:itemTextColor="@color/wh_on_muted"
            app:itemIconTint="@color/wh_on_muted"/>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
