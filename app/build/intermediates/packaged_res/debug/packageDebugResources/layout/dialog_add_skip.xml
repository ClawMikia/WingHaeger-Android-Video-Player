<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/wh_surface_elevated">

    <TextView
        android:id="@+id/tvSkipDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ADD SKIP SEGMENT"
        android:fontFamily="@font/orbitron_bold"
        android:textSize="14sp"
        android:textColor="@color/wh_neon_pink"
        android:letterSpacing="0.15"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.WH.TextInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Start (e.g. 1:30)"
        android:layout_marginBottom="12dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSkipStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:fontFamily="@font/orbitron_regular"
            android:textColor="@color/wh_on_bg"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.WH.TextInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="End (e.g. 2:00)"
        android:layout_marginBottom="16dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSkipEnd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:fontFamily="@font/orbitron_regular"
            android:textColor="@color/wh_on_bg"/>
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/btnCancel"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="46dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_btn_red"
            android:text="CANCEL"
            android:fontFamily="@font/orbitron_bold"
            android:textColor="@color/wh_neon_red" android:textSize="11sp"/>
        <Button android:id="@+id/btnSave"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="46dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_btn_gold"
            android:text="CONFIRM"
            android:fontFamily="@font/orbitron_bold"
            android:textColor="@color/wh_neon_gold" android:textSize="11sp"/>
    </LinearLayout>
</LinearLayout>
