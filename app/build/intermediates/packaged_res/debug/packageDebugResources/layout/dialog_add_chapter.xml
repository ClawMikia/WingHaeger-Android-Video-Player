<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/wh_surface_elevated">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MARK CHAPTER"
        android:fontFamily="@font/orbitron_bold"
        android:textSize="14sp"
        android:textColor="@color/wh_neon_gold"
        android:letterSpacing="0.15"
        android:gravity="center"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:id="@+id/tvTimestamp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="at 0:00"
        android:fontFamily="@font/orbitron_regular"
        android:textSize="11sp"
        android:textColor="@color/wh_neon_cyan"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.WH.TextInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Chapter Label"
        android:layout_marginBottom="16dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etChapterName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/orbitron_regular"
            android:textColor="@color/wh_on_bg"/>
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal">
        <ImageButton
            android:id="@+id/btnCancel"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="46dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_btn_red"
            android:src="@drawable/ic_close_custom"
            android:scaleType="fitCenter" android:padding="10dp"/>
        <ImageButton
            android:id="@+id/btnAdd"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="46dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_btn_gold"
            android:src="@drawable/ic_check"
            android:scaleType="fitCenter" android:padding="10dp"/>
    </LinearLayout>
</LinearLayout>
